@prefix coso: <http://w3id.org/coso/v1/contaminoso#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix us_sdwis: <http://sawgraph.spatialai.org/v1/us-sdwis#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://sawgraph.spatialai.org/v1/us-sdwis> rdf:type owl:Ontology ;
                                            owl:versionIRI us_sdwis: ;
                                            dcterms:created "2025-02-18"@en-us ;
                                            dcterms:creator <https://orcid.org/0000-0003-3271-6700> ;
                                            dcterms:description "US Safe Drinking Water Information System PFAS Sample schema for SAWGraph"@en-us ;
                                            dcterms:issued "2025-02-18"^^xsd:date ;
                                            dcterms:modified "2026-05-21"^^xsd:date ;
                                            dcterms:publisher <http://spatialai.org> ;
                                            dcterms:source "https://raw.githubusercontent.com/SAWGraph/water-kg/refs/heads/main/datasets/sdwis/us-sdwis-sample-schema.ttl"^^<xsd:anyURI> ;
                                            dcterms:title "SAWGraph SDWIS PFAS Sample Schema"@en-us ;
                                            owl:versionInfo "0.0.8"@en-us .


#################################################################
#    Classes
#################################################################

us_sdwis:PWS-PFAS rdf:type owl:Class ;
                  rdfs:subClassOf coso:Substance ;
				  rdfs:label "PWS-PFAS" .

us_sdwis:Amount rdf:type owl:Class ;
                rdfs:subClassOf qudt:QuantityValue ;
				rdfs:label "Amount" .

us_sdwis:PWS-PFASConcentration rdf:type owl:Class ;
                               rdfs:subClassOf coso:ContaminantRelativeMeasurement ,
							                   coso:SingleContaminantMeasurement ;
                               #rdfs:subClassOf pfas:PFAS-ConcentrationMeasurement ;
							   rdfs:label "PWS-PFASConcentration" .

us_sdwis:PWS-Observation rdf:type owl:Class ;
                         rdfs:subClassOf coso:ContaminantSampleObservation ;
                         #rdfs:subClassOf pfas:PFAS-SampleContaminantObservation ;
						 rdfs:label "PWS-Observation" . 

us_sdwis:PWS-Sample rdf:type owl:Class ;
                    rdfs:subClassOf coso:MaterialSample ;
					rdfs:label "PWS-Sample" . 

us_sdwis:PWS-SamplePoint rdf:type owl:Class ;
                         rdfs:subClassOf coso:SamplePoint ;
						 rdfs:label "PWS-SamplePoint" . 

us_sdwis:SampledFeature rdf:type owl:Class ;
                        rdfs:subClassOf coso:SampledFeature ;
						rdfs:label "SampledFeature" .
