@prefix coso: <http://w3id.org/coso/v1/contaminoso#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix us_sdwis: <http://sawgraph.spatialai.org/v1/us-sdwis#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://sawgraph.spatialai.org/v1/us-sdwis> rdf:type owl:Ontology ;
                                            owl:versionIRI us_sdwis: ;
                                            dcterms:created "2025-02-18"@en-us ;
                                            dcterms:creator <https://orcid.org/0000-0003-3271-6700> ; # Katrina Schweikert
                                            dcterms:description "US Safe Drinking Water Information System schema for SAWGraph"@en-us ;
                                            dcterms:issued "2025-02-18"^^xsd:date ;
                                            dcterms:modified "2026-05-21"^^xsd:date ;
                                            dcterms:publisher <http://spatialai.org> ;
                                            dcterms:source "https://raw.githubusercontent.com/SAWGraph/water-kg/refs/heads/main/datasets/sdwis/us-sdwis-schema.ttl"^^<xsd:anyURI> ;
                                            dcterms:title "SAWGraph SDWIS Schema"@en-us ;
                                            owl:versionInfo "0.0.8"@en-us ;
											prov:wasAttributedTo <https://sawgraph.github.io> .


#################################################################
#    Object Properties
#################################################################

us_sdwis:serviceArea rdf:type owl:ObjectProperty ;
                     rdfs:domain us_sdwis:PublicWaterSystem ;
                     rdfs:range us_sdwis:PWS-ServiceArea ;
                     rdfs:label "serviceArea" ;
					 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:inCombinedSystem rdf:type owl:ObjectProperty ;
                          rdfs:domain us_sdwis:PublicWaterSystem ;
                          rdfs:range us_sdwis:CombinedDistributionSystem ;
                          rdfs:label "inCombinedSystem" ;
						  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:hasPart rdf:type owl:ObjectProperty ;
                 owl:inverseOf us_sdwis:partOf ;
                 rdfs:domain us_sdwis:PublicWaterSystem ;
                 rdfs:range us_sdwis:PWS-SubFeature ;
                 rdfs:label "hasPart" ;
				 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 

us_sdwis:hasSource rdf:type owl:ObjectProperty ,
                            owl:AsymmetricProperty ;
                   owl:inverseOf us_sdwis:sourceFor ;
                   rdfs:domain us_sdwis:PublicWaterSystem ;
                   rdfs:range us_sdwis:PWS-SubFeature ;
                   rdfs:label "hasSource" ;
				   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:sellsTo rdf:type owl:ObjectProperty ;
                 rdfs:domain us_sdwis:PublicWaterSystem ;
                 rdfs:range us_sdwis:PublicWaterSystem ;
                 owl:inverseOf us_sdwis:buysFrom ;
                 rdfs:label "sellsTo" ;
				 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 

us_sdwis:primarySourceType rdf:type owl:ObjectProperty ;
                           rdfs:domain us_sdwis:PublicWaterSystem ;
                           rdfs:range us_sdwis:PWS-SourceWaterType ;
                           rdfs:label "primarySourceType" ;
						   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:serviceAreaType rdf:type owl:ObjectProperty ;
                         rdfs:domain us_sdwis:PWS-ServiceArea ;
                         rdfs:range us_sdwis:PWS-ServiceAreaType ;
                         rdfs:label "serviceAreaType" ;
						 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:hasPermanentSource rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf us_sdwis:hasSource ;
                            rdfs:label "hasPermanentSource" ;
							rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 


#################################################################
#    Datatype properties
#################################################################

us_sdwis:hasPWSID rdf:type owl:DatatypeProperty ;
                  rdfs:domain us_sdwis:PublicWaterSystem ;
                  rdfs:label "hasPWSID" ;
				  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 

us_sdwis:pwsName rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf rdfs:label ;
                 rdfs:domain us_sdwis:PublicWaterSystem ;
                 rdfs:label "pwsName" ;
				 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:populationServed rdf:type owl:DatatypeProperty ;
                          rdfs:domain us_sdwis:PublicWaterSystem ;
                          rdfs:label "populationServed" ;
						  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:sizeCategory rdf:type owl:DatatypeProperty ;
                      rdfs:domain us_sdwis:PublicWaterSystem ;
                      rdfs:label "sizeCategory" ;
					  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:deactivationDate rdf:type owl:DatatypeProperty ;
                          rdfs:domain us_sdwis:PublicWaterSystem ;
                          rdfs:label "deactivationDate" ;
						  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:hasMethod rdf:type owl:DatatypeProperty ;
                   rdfs:domain us_sdwis:PWS-ServiceArea ;
                   rdfs:label "hasMethod" ;
				   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:hasOwnership rdf:type owl:DatatypeProperty ;
                      rdfs:label "hasOwnership" ;
					  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:primarySource rdf:type owl:DatatypeProperty ;
                       rdfs:label "primarySource" ;
					   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 

us_sdwis:firstReport rdf:type owl:DatatypeProperty ;
                     rdfs:label "firstReport" ;
					 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:lastReport rdf:type owl:DatatypeProperty ;
                    rdfs:label "lastReport" ;
					rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> . 


#################################################################
#    Classes
#################################################################

us_sdwis:PublicWaterSystem rdf:type owl:Class ;
                           rdfs:subClassOf geo:Feature ;
                           owl:equivalentClass [
                                                 rdf:type owl:Restriction ;
                                                 owl:onProperty us_sdwis:hasSource ;
                                                 owl:someValuesFrom us_sdwis:PWS-SubFeature
                                               ] ;
                           rdfs:label "Public Water System (PWS)" ;
                           rdfs:comment "All PWS have some water source, even if unidentified" ;
						   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-CWS rdf:type owl:Class ;
                               rdfs:subClassOf us_sdwis:PublicWaterSystem ;
                               rdfs:label "Community Water System" ;
							   rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-NCWS rdf:type owl:Class ;
                                rdfs:subClassOf us_sdwis:PublicWaterSystem ;
                                owl:disjointWith us_sdwis:PublicWaterSystem-CWS ;
                                rdfs:label "Non-Community Water System" ;
								rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-NTNCWS rdf:type owl:Class ;
                                  rdfs:subClassOf us_sdwis:PublicWaterSystem-NCWS ;
                                  rdfs:label "Non-Transient Non-Community Water System" ;
								  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-TNCWS rdf:type owl:Class ;
                                 rdfs:subClassOf us_sdwis:PublicWaterSystem-NCWS ;
                                 owl:disjointWith us_sdwis:PublicWaterSystem-NTNCWS ;
                                 rdfs:label "Transient Non-Community Water System" ;
								 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-GW rdf:type owl:Class ;
                              rdfs:subClassOf us_sdwis:PublicWaterSystem ;
                              rdfs:label "PWS Groundwater" ;
							  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PublicWaterSystem-SW rdf:type owl:Class ;
                              rdfs:subClassOf us_sdwis:PublicWaterSystem ;
                              rdfs:label "PWS Surface Water" ;
							  rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:CombinedDistributionSystem rdf:type owl:Class ;
                                    rdfs:subClassOf geo:FeatureCollection ;
                                    rdfs:label "Combined Distribution System" ;
									rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-ServiceArea rdf:type owl:Class ;
                         rdfs:subClassOf geo:Feature ;
                         rdfs:label "PWS Service Area" ;
						 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-ServiceAreaType rdf:type owl:Class ;
                             rdfs:label "PWS Service Area Type" ;
							 rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-SubFeature rdf:type owl:Class ;
                        rdfs:label "PWS SubFeature" ;
						rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-SubFeatureType rdf:type owl:Class ;
                            rdfs:label "PWS SubFeature Type" ;
							rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-SubFeatureActivity rdf:type owl:Class ;
                                rdfs:label "PWS SubFeature Activity" ;
								rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .

us_sdwis:PWS-SourceWaterType rdf:type owl:Class ;
                             rdfs:label "PWS Source Water Type" ;
					         rdfs:isDefinedBy <http://sawgraph.spatialai.org/v1/us-sdwis> .


